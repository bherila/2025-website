{
  "name": "2025-website",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "workspaceFolder": "/workspaces/2025-website",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/node:2": {
      "version": "24",
      "pnpmVersion": "11",
      "nodeGypDependencies": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteEnv": {
    "XDEBUG_MODE": "off",
    "COMPOSER_NO_INTERACTION": "1",
    "COMPOSER_ALLOW_SUPERUSER": "1"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [
    5173,
    8000
  ],
  "portsAttributes": {
    "5173": {
      "label": "Vite",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "Laravel",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "codespaces": {
      "repositories": {
        "bherila/auth": {
          "permissions": {
            "contents": "read",
            "packages": "read"
          }
        },
        "bherila/ui": {
          "permissions": {
            "contents": "read",
            "packages": "read"
          }
        },
        "bherila/genai-laravel": {
          "permissions": {
            "contents": "read",
            "packages": "read"
          }
        }
      }
    },
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "php.validate.executablePath": "/usr/local/bin/php",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "hostRequirements": {
    "cpus": 2,
    "memory": "8gb",
    "storage": "32gb"
  }
}
