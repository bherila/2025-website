{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test": "jest --passWithNoTests",
        "test:ci:app": "JEST_EXCLUDE_GAME_TESTS=1 jest --passWithNoTests",
        "test:ci:marble-sort": "jest --passWithNoTests resources/js/games/marble-sort",
        "test:ci:parking-pickup": "jest --passWithNoTests resources/js/games/cars",
        "test:slow": "JEST_INCLUDE_SLOW_TESTS=1 jest --passWithNoTests --testPathPattern='\\.slow\\.test\\.[tj]sx?$'",
        "test:e2e": "playwright test",
        "test:e2e:parking-pickup": "playwright test tests/e2e/parking-pickup.spec.ts",
        "type-check": "tsc --noEmit --jsx react-jsx",
        "type-check:e2e": "tsc --noEmit -p tsconfig.playwright.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "pnpm": {
        "overrides": {
            "glob": ">=10.5.0"
        },
        "onlyBuiltDependencies": [
            "esbuild",
            "unrs-resolver"
        ]
    },
    "devDependencies": {
        "@eslint-react/eslint-plugin": "^5.7.8",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.60.0",
        "@swc/core": "^1.15.33",
        "@swc/jest": "^0.2.39",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.3.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.19.19",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.184.1",
        "@vitejs/plugin-react": "^6.0.2",
        "autoprefixer": "^10.5.0",
        "axios": "^1.16.1",
        "concurrently": "^9.2.1",
        "eslint": "^10.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.6.0",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "laravel-vite-plugin": "^3.1.0",
        "postcss": "^8.5.14",
        "tailwindcss": "^4.3.0",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.3",
        "vite": "^8.0.13"
    },
    "dependencies": {
        "@base-ui/react": "^1.4.1",
        "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
        "@hookform/resolvers": "^5.2.2",
        "@sentry/react": "^10.53.1",
        "@stripe/react-stripe-js": "^6.3.0",
        "@stripe/stripe-js": "^9.5.0",
        "@tanstack/react-virtual": "^3.13.24",
        "@toon-format/toon": "^2.2.0",
        "cannon-es": "^0.20.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "currency.js": "^2.0.4",
        "date-fns": "^4.1.0",
        "dayjs": "^1.11.20",
        "idb": "^8.0.3",
        "lucide-react": "^1.16.0",
        "mermaid": "11.15.0",
        "pdfjs-dist": "5.4.149",
        "react": "^19.2.6",
        "react-day-picker": "^10.0.0",
        "react-dom": "^19.2.6",
        "react-hook-form": "^7.75.0",
        "react-markdown": "^10.1.0",
        "react-responsive-masonry": "^2.7.2",
        "recharts": "^3.8.1",
        "remark-gfm": "^4.0.1",
        "shiki": "4.1.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "three": "^0.184.0",
        "zod": "^4.4.3"
    }
}
